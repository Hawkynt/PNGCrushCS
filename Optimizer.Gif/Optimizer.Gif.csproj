<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>

    <Description>GIF optimization engine with palette reordering, LZW re-encoding, and frame optimization.</Description>
    <PackageReadmeFile>ReadMe.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/Hawkynt/PNGCrush</PackageProjectUrl>
    <PackageTags>GifOptimizer;ImageCrush;Hawkynt</PackageTags>
    <RepositoryUrl>https://github.com/Hawkynt/PNGCrush</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Optimizer.Gif.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\AnythingToGif\GifFileFormat\GifFileFormat.csproj" />
    <ProjectReference Include="..\Crush.Core\Crush.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Drawing.Common" Version="9.0.4" />
  </ItemGroup>

</Project>
