    <ProjectReference Include="..\..\FileFormat.Qoi\FileFormat.Qoi.csproj" />
    <ProjectReference Include="..\..\FileFormat.Tga\FileFormat.Tga.csproj" />
    <ProjectReference Include="..\..\FileFormat.Farbfeld\FileFormat.Farbfeld.csproj" />
    <ProjectReference Include="..\..\FileFormat.Netpbm\FileFormat.Netpbm.csproj" />
    <ProjectReference Include="..\..\FileFormat.Aai\FileFormat.Aai.csproj" />
    <ProjectReference Include="..\..\FileFormat.Cmu\FileFormat.Cmu.csproj" />
    <ProjectReference Include="..\..\FileFormat.Hrz\FileFormat.Hrz.csproj" />
    <ProjectReference Include="..\..\FileFormat.Wbmp\FileFormat.Wbmp.csproj" />
    <ProjectReference Include="..\..\FileFormat.Sgi\FileFormat.Sgi.csproj" />
    <ProjectReference Include="..\..\FileFormat.WebP\FileFormat.WebP.csproj" />
