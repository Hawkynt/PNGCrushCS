<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0-windows</TargetFramework>
        <ImplicitUsings>disable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>preview</LangVersion>

        <Version>1.0.0</Version>
        <Authors>Hawkynt</Authors>
        <Description>This package provides a PngOptimizer implementation.</Description>
        <PackageReadmeFile>ReadMe.md</PackageReadmeFile>
        <PackageProjectUrl>https://github.com/Hawkynt/PNGCrush</PackageProjectUrl>
        <PackageTags>PNGCrush;Hawkynt</PackageTags>
        <RepositoryUrl>https://github.com/Hawkynt/PNGCrush</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageLicenseExpression>LGPL-3.0-or-later</PackageLicenseExpression>
        <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="PngOptimizer.Tests" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Compression.Core\Compression.Core.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="FrameworkExtensions.Backports" Version="1.0.0.256" />
        <PackageReference Include="FrameworkExtensions.Corlib" Version="1.0.2.459" />
        <PackageReference Include="FrameworkExtensions.System.Drawing" Version="1.0.0.132" />
        <PackageReference Include="System.Drawing.Common" Version="9.0.4" />
    </ItemGroup>

</Project>